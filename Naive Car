# ---------------------------------------------------
# IMPORT LIBRARIES
# ---------------------------------------------------

import pandas as pd
from sklearn.preprocessing import LabelEncoder
from sklearn.naive_bayes import GaussianNB

# ---------------------------------------------------
# CREATE DATASET
# ---------------------------------------------------

data = {
    'Color': ['Red', 'Blue', 'Black', 'White', 'Red', 'Black'],
    'Type': ['SUV', 'Sedan', 'SUV', 'Sedan', 'SUV', 'Sedan'],
    'Buy': ['Yes', 'No', 'Yes', 'No', 'Yes', 'No']
}

df = pd.DataFrame(data)

# ---------------------------------------------------
# DISPLAY DATASET
# ---------------------------------------------------

print("DATASET")
print(df)

# ---------------------------------------------------
# FEATURES AND TARGET
# ---------------------------------------------------

X = df[['Color', 'Type']].copy()

y = df['Buy']

# ---------------------------------------------------
# ENCODING
# ---------------------------------------------------

encoder_color = LabelEncoder()

X['Color'] = encoder_color.fit_transform(X['Color'])

encoder_type = LabelEncoder()

X['Type'] = encoder_type.fit_transform(X['Type'])

encoder_y = LabelEncoder()

y = encoder_y.fit_transform(y)

# ---------------------------------------------------
# CREATE MODEL
# ---------------------------------------------------

model = GaussianNB()

# ---------------------------------------------------
# TRAIN MODEL
# ---------------------------------------------------

model.fit(X, y)

# ---------------------------------------------------
# TEST DATA
# ---------------------------------------------------

new_data = pd.DataFrame(
    [['Red', 'SUV']],
    columns=['Color', 'Type']
)

new_data['Color'] = encoder_color.transform(
    new_data['Color']
)

new_data['Type'] = encoder_type.transform(
    new_data['Type']
)

# ---------------------------------------------------
# PREDICTION
# ---------------------------------------------------

prediction = model.predict(new_data)

# ---------------------------------------------------
# DISPLAY RESULT
# ---------------------------------------------------

result = encoder_y.inverse_transform(prediction)

print("\nPREDICTED RESULT")
print(result)
