# ---------------------------------------------------
# IMPORT LIBRARIES
# ---------------------------------------------------

import pandas as pd
from sklearn.preprocessing import LabelEncoder
from sklearn.naive_bayes import GaussianNB

# ---------------------------------------------------
# READ EXCEL FILE
# ---------------------------------------------------

df = pd.read_excel("house.xlsx")

# ---------------------------------------------------
# DISPLAY DATASET
# ---------------------------------------------------

print("DATASET")
print(df)

# ---------------------------------------------------
# FEATURES AND TARGET
# ---------------------------------------------------

X = df[['Area']]

y = df['Price']

# ---------------------------------------------------
# ENCODING
# ---------------------------------------------------

encoder = LabelEncoder()

y = encoder.fit_transform(y)

# ---------------------------------------------------
# CREATE MODEL
# ---------------------------------------------------

model = GaussianNB()

# ---------------------------------------------------
# TRAIN MODEL
# ---------------------------------------------------

model.fit(X, y)

# ---------------------------------------------------
# TEST DATA
# ---------------------------------------------------

new_data = pd.DataFrame(
    [[1050]],
    columns=['Area']
)

# ---------------------------------------------------
# PREDICTION
# ---------------------------------------------------

prediction = model.predict(new_data)

# ---------------------------------------------------
# DISPLAY RESULT
# ---------------------------------------------------

result = encoder.inverse_transform(prediction)

print("\nPREDICTED PRICE")
print(result)
