# ---------------------------------------------------
# IMPORT LIBRARIES
# ---------------------------------------------------

import pandas as pd
from sklearn.preprocessing import LabelEncoder
from sklearn.naive_bayes import GaussianNB

# ---------------------------------------------------
# READ EXCEL FILE
# ---------------------------------------------------

df = pd.read_excel("weather.xlsx")

# ---------------------------------------------------
# DISPLAY DATASET
# ---------------------------------------------------

print("DATASET")
print(df)

# ---------------------------------------------------
# FEATURES AND TARGET
# ---------------------------------------------------

X = df[['Outlook']].copy()

y = df['Play']

# ---------------------------------------------------
# ENCODING
# ---------------------------------------------------

encoder_X = LabelEncoder()

X['Outlook'] = encoder_X.fit_transform(X['Outlook'])

encoder_y = LabelEncoder()

y = encoder_y.fit_transform(y)

# ---------------------------------------------------
# CREATE MODEL
# ---------------------------------------------------

model = GaussianNB()

# ---------------------------------------------------
# TRAIN MODEL
# ---------------------------------------------------

model.fit(X, y)

# ---------------------------------------------------
# TEST DATA
# ---------------------------------------------------

new_data = pd.DataFrame(
    [['Sunny']],
    columns=['Outlook']
)

new_data['Outlook'] = encoder_X.transform(
    new_data['Outlook']
)

# ---------------------------------------------------
# PREDICTION
# ---------------------------------------------------

prediction = model.predict(new_data)

# ---------------------------------------------------
# DISPLAY RESULT
# ---------------------------------------------------

result = encoder_y.inverse_transform(prediction)

print("\nPREDICTED RESULT")
print(result)
