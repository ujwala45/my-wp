# ---------------------------------------------------
# IMPORT LIBRARIES
# ---------------------------------------------------

import pandas as pd
from sklearn.preprocessing import LabelEncoder
from sklearn.naive_bayes import GaussianNB

# ---------------------------------------------------
# READ EXCEL FILE
# ---------------------------------------------------

df = pd.read_excel("diabetes.xlsx")

# ---------------------------------------------------
# DISPLAY DATASET
# ---------------------------------------------------

print("DATASET")
print(df)

# ---------------------------------------------------
# CREATE CLASS COLUMN
# ---------------------------------------------------

df['Class'] = ['Diabetic', 'Non-Diabetic',
               'Non-Diabetic', 'Non-Diabetic',
               'Diabetic', 'Diabetic']

print("\nUPDATED DATASET")
print(df)

# ---------------------------------------------------
# FEATURES AND TARGET
# ---------------------------------------------------

X = df[['Age', 'Glucose']]

y = df['Class']

# ---------------------------------------------------
# ENCODING
# ---------------------------------------------------

encoder = LabelEncoder()

y = encoder.fit_transform(y)

# ---------------------------------------------------
# CREATE MODEL
# ---------------------------------------------------

model = GaussianNB()

# ---------------------------------------------------
# TRAIN MODEL
# ---------------------------------------------------

model.fit(X, y)

# ---------------------------------------------------
# TEST DATA
# ---------------------------------------------------

new_data = pd.DataFrame(
    [[50, 90]],
    columns=['Age', 'Glucose']
)

# ---------------------------------------------------
# PREDICTION
# ---------------------------------------------------

prediction = model.predict(new_data)

# ---------------------------------------------------
# DISPLAY RESULT
# ---------------------------------------------------

result = encoder.inverse_transform(prediction)

print("\nPREDICTED RESULT")
print(result)
