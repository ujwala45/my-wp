# ---------------------------------------------------
# IMPORT LIBRARIES
# ---------------------------------------------------

import pandas as pd
from sklearn.neighbors import KNeighborsClassifier
import matplotlib.pyplot as plt

# ---------------------------------------------------
# READ EXCEL FILE
# ---------------------------------------------------

df = pd.read_excel("leaf.xlsx")

# ---------------------------------------------------
# DISPLAY DATASET
# ---------------------------------------------------

print("DATASET")
print(df)

# ---------------------------------------------------
# SEPARATE FEATURES AND LABELS
# ---------------------------------------------------

X = df[['Moisture', 'Temperature']]

y = df['Class']

# ---------------------------------------------------
# CREATE KNN MODEL
# ---------------------------------------------------

model = KNeighborsClassifier(n_neighbors=3)

# ---------------------------------------------------
# TRAIN THE MODEL
# ---------------------------------------------------

model.fit(X, y)

# ---------------------------------------------------
# NEW LEAF DATA (TEST DATA)
# ---------------------------------------------------

new_data = pd.DataFrame(
    [[75, 26]],
    columns=['Moisture', 'Temperature']
)

# ---------------------------------------------------
# PREDICT RESULT
# ---------------------------------------------------

prediction = model.predict(new_data)

# ---------------------------------------------------
# DISPLAY RESULT
# ---------------------------------------------------

print("\nPREDICTED RESULT")
print(prediction)

# ---------------------------------------------------
# VISUALIZATION
# ---------------------------------------------------

colors = []

for value in y:
    
    if value == 'Healthy':
        colors.append('green')
        
    else:
        colors.append('red')

plt.scatter(
    df['Moisture'],
    df['Temperature'],
    c=colors
)

plt.xlabel("Moisture")

plt.ylabel("Temperature")

plt.title("Leaf Classification using KNN")

plt.show()
